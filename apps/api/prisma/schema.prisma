// Disco persistence model. The API uses an in-memory Repo by default (zero-setup demo); this Prisma
// schema is the production drop-in behind the same `Repo` interface (apps/api/src/repo.ts).
//   pnpm --filter @disco/api exec prisma migrate dev
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operator {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Append-only accountability log for destructive operations (client/snapshot delete, build cancel,
/// password change). Operator-visible for debugging + a trust record on a high-value delivery.
model AuditLog {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  action   String // e.g. client.delete | snapshot.delete | build.cancel | handover.password
  target   String // human label of what was acted on
  detail   String   @default("")
  operator String // who did it (operator email)

  @@index([at])
}

/// Build-lifecycle event log (#12) — the operator-facing "webhook event log": one row per build
/// transition (started / completed / failed / resumed), with a short human detail.
model BuildEvent {
  id         String   @id @default(cuid())
  jobId      String
  at         DateTime @default(now())
  kind       String
  detail     String   @default("")
  ownerEmail String   @default("") // multi-operator scoping (copied from the owning job)

  @@index([jobId])
  @@index([at])
  @@index([ownerEmail])
}

/// One anonymous open of a public handover page (#14). Referrer ORIGIN only — never an IP or any
/// other identifier — an engagement signal, not surveillance.
model HandoverView {
  id          String   @id @default(cuid())
  handoverId  String
  at          DateTime @default(now())
  referrer    String   @default("")
  kind        String   @default("opened") // opened | report_downloaded | docs_viewed | share_viewed

  @@index([handoverId])
}

/// A versioned, captured template. The full typed artifact lives in `artifact` (Snapshot JSON).
model Snapshot {
  id            String    @id @default(cuid())
  name          String
  version       Int
  sourceGuildId String
  schemaVersion String
  capturedAt    DateTime
  artifact      Json
  tags          String[]  @default([])
  note          String    @default("")
  favorite      Boolean   @default(false)
  isTemplate    Boolean   @default(false)
  lastUsedAt    DateTime?
  ownerEmail    String    @default("") // multi-operator access scoping
  createdAt     DateTime  @default(now())
  jobs          Job[]

  @@index([sourceGuildId, version])
  @@index([ownerEmail])
}

/// A saved client (creator) for repeat builds + upsells.
model Client {
  id          String   @id @default(cuid())
  creatorName String
  handle      String   @default("")
  brandColors String[] @default([])
  links       String[] @default([])
  termSwaps   Json     @default("[]")
  assets      Json     @default("{}")
  notes       String   @default("")
  buildPrice      Float @default(0)
  monthlyRetainer Float @default(0)
  upsells         Json  @default("[]")
  stripeSessionId String? @unique // idempotent Stripe fulfilment: one client per checkout session
  ownerEmail  String   @default("") // multi-operator access scoping
  createdAt   DateTime @default(now())
  jobs        Job[]
  handovers   Handover[]

  @@index([ownerEmail])
}

/// A rebrand+build run. Resumable: `manifest` holds per-step state + localRef→newId mappings.
model Job {
  id            String    @id @default(cuid())
  kind          String // snapshot | rebuild
  status        String // queued | running | paused | completed | failed | canceled
  dryRun        Boolean   @default(false)
  canary        Boolean   @default(false)
  progress      Float     @default(0)
  targetGuildId String?
  rebrandConfig Json      @default("{}")
  metrics       Json?
  manifest      Json?
  report        Json?
  error         String?
  ownerEmail    String    @default("") // multi-operator access scoping
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  snapshot      Snapshot? @relation(fields: [snapshotId], references: [id])
  snapshotId    String?
  client        Client?   @relation(fields: [clientId], references: [id])
  clientId      String?
  handover      Handover?

  @@index([createdAt]) // the /jobs list orders by this on every poll (Queue/Activity/Today/Economics)
  @@index([clientId]) // deleteClient unlinks by this; Postgres doesn't auto-index relation scalars
  @@index([snapshotId])
  @@index([ownerEmail])
}

/// The client delivery record: handover page state + ownership-transfer checklist + upsell tracking.
model Handover {
  id              String   @id @default(cuid())
  job             Job      @relation(fields: [jobId], references: [id])
  jobId           String   @unique
  client          Client?  @relation(fields: [clientId], references: [id])
  clientId        String?
  /// hash of an optional password protecting the public handover page
  passwordHash    String?
  state           String   @default("draft") // draft | ready | handed_over
  logoKey         String?
  welcomeMessage  String   @default("")
  ownershipSteps  Json     @default("[]")
  upsellStatus    String   @default("none") // none | proposed | retained | redesign
  ownerEmail      String   @default("") // multi-operator access scoping
  createdAt       DateTime @default(now())

  @@index([ownerEmail])
}
