# ─────────────────────────────────────────────────────────────────────────────
# Disco environment — copy to .env and fill in. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord bot ──────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# Enable privileged intents: SERVER MEMBERS, MESSAGE CONTENT, PRESENCE not needed.
# Bot needs Administrator in BOTH the source (template) and target (client) guilds.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# Optional: set to a throwaway test guild id for the safe mock/dry-run flows.
DISCORD_TEST_GUILD_ID=

# ── Postgres ─────────────────────────────────────────────────────────────────
# docker-compose provisions this automatically; override for external DBs.
DATABASE_URL=postgresql://disco:disco@localhost:5432/disco?schema=public
POSTGRES_USER=disco
POSTGRES_PASSWORD=disco
POSTGRES_DB=disco

# ── Redis (BullMQ queue) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=4000
# Public base the web dashboard uses to reach the API.
PUBLIC_API_URL=http://localhost:4000

# ── Auth (multi-operator) ────────────────────────────────────────────────────
# OPERATOR_EMAIL is the bootstrap ADMIN — its password is env-configured (below) and it can invite
# additional operators in-app (Preferences → account & team). Those extra operators are stored in the
# DB, are owner-SCOPED (each sees only their own clients/builds), and manage their own password in-app.
OPERATOR_EMAIL=operator@example.com
# bcrypt hash of the ADMIN password. Generate with: pnpm --filter @disco/api hash-password
OPERATOR_PASSWORD_HASH=
# Optional: comma-separated ADDITIONAL admin emails (defaults to just OPERATOR_EMAIL). SECURITY: any email
# listed here is admin at login — so you CANNOT invite a DB operator with an email in this set (the app
# rejects it, and such a DB row can't log in). Leave unset unless you truly want multiple env-level admins.
ADMIN_EMAILS=
# 32+ char random string used to sign session JWTs. REQUIRED in production — the API REFUSES to boot
# with a live bot token / Postgres / NODE_ENV=production unless this is set to a unique value (anyone
# could otherwise forge an operator JWT). Generate one: openssl rand -base64 48
SESSION_SECRET=

# ── Stripe (optional sales flow — checkout + webhook fulfilment) ──────────────
# Leave BOTH unset for the scaffold (no real charges). To go live, set both — the webhook FAILS CLOSED
# (rejects unsigned events) whenever a live key is present without a signing secret. See docs/stripe-go-live.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Object storage (snapshot asset bytes: icons, emojis, banners) ────────────
# dev: local disk. prod: any S3-compatible endpoint.
STORAGE_DRIVER=disk
STORAGE_DISK_PATH=./storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Web dashboard ────────────────────────────────────────────────────────────
WEB_PORT=5173
VITE_API_URL=http://localhost:4000

# ── Handover pages ───────────────────────────────────────────────────────────
# Optional global salt for password-protected handover links.
HANDOVER_LINK_SECRET=
